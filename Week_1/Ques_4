// 2022B - Kar Salesman on codeforces

#include <bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;
    while (t--)
    {
        int n;
        long long x;
        cin >> n >> x;
        
        long long sum = 0, mx = 0;
        for (int i = 0; i < n; i++)
        {
            long long val;
            cin >> val;
            sum += val;
            mx = max(mx, val);
        }
        
        long long ans = max(mx, (sum + x - 1) / x);
        cout << ans << "\n";
    }
    return 0;
}
